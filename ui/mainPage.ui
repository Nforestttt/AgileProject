  <property name="styleSheet">
   <string notr="true">/* 整体窗口背景 */
QWidget#Form{
        background:qlineargradient(
        x1:0, y1:0,
        x2:1, y2:1,
        stop:0 #727272,
        stop:1 #ffd6e0
    );
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
}


/* 左侧侧边栏 */
QWidget#horizontalLayoutWidget{
    background-color: transparent;
}


/* Logo */
QLabel#label{
    font-size: 26px;
    font-weight: bold;
    color: #ff6b81;
    padding: 20px;
}


/* 左侧按钮统一样式 */
QPushButton{
    background-color: transparent;
    border: none;

    font-family: &quot;Segoe UI Semibold&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 15px;
    font-weight: bold;

    padding: 12px 20px;
    margin-left: 10px;
    margin-right: 10px;

    text-align: left;
    color: #444;

    border-radius: 10px;
}


QPushButton:hover{
    background-color: #ffe4ea;
    color: #ff4f70;
}


QPushButton:pressed{
    background-color: #ffd2dc;
}


/* 当前选中按钮（可手动加）*/
QPushButton:checked{
    background-color: #ffccd5;
    color: #d6336c;
}


/* 右侧页面区域 */
QWidget#PageArea{
    background-color: #ffffff;
    border-radius: 12px;
    margin: 10px;
}


/* 页面文字 */
QLabel#label_2,
QLabel#label_3,
QLabel#label_4{
    font-size: 22px;
    color: #444;
}


/* stackedWidget背景 */
QStackedWidget{
    background-color: transparent;
}

/* 针对所有滚动区域及其内部容器 */
QScrollArea, #scrollAreaWidgetContents, #scrollAreaWidgetContents_2, #scrollAreaWidgetContents_3 {
    background-color: #ffffff; /* 或者设置为 #ffffff (纯白) */
    border: none;
}

/* 如果你想让右侧题目区域背景是纯白的，左侧稍微带点灰 */
#test_scroll #scrollAreaWidgetContents_3 {
    background-color: #ffffff;
}

#book_scroll #scrollAreaWidgetContents_2 {
    background-color: #ffffff; /* 浅灰色，突出侧边栏感觉 */
}

/* 自定义滚动条样式，让它变细且美观 */
QScrollBar:vertical {
    border: none;
    background: #f1f1f1;
    width: 6px;
    border-radius: 3px;
}
QScrollBar::handle:vertical {
    background: #ffccd5;
    border-radius: 3px;
}
QScrollBar::handle:vertical:hover {
    background: #ff6b81;
}

/* --- 左侧书籍选择按钮 (book_scroll) --- */
#book_scroll QPushButton {
    background-color: transparent;
    border: none;
    color: #666;
    padding: 12px 5px;
    font-size: 14px;
    text-align: center;
    border-bottom: 1px solid #f0f0f0;
}

#book_scroll QPushButton:hover {
    background-color: #fff0f3;
    color: #ff6b81;
}

#book_scroll QPushButton:checked {
    background-color: #ffffff;
    color: #ff6b81;
    font-weight: bold;
    border-left: 4px solid #ff6b81; /* 选中时的左侧粉色条 */
}

/* --- 右侧测试卡片 (test_scroll) --- */
/* 针对 frame 和 frame_3 这种卡片容器 */
QFrame#frame, QFrame#frame_3 {
    background-color: #ffffff;
    border: 1px solid #eee;
    border-radius: 12px;
    margin: 5px 10px;
}

QFrame#frame:hover, QFrame#frame_3:hover {
    border: 1px solid #ffccd5;
    background-color: #fffafa;
}

/* 标题文字 (Part 1 Section 1) */
QLabel#label_7, QLabel#label_10 {
    font-weight: bold;
    font-size: 16px;
    color: #333;
}

/* 副标题文字 (Recommendation for restaurant) */
QLabel#label_8, QLabel#label_11 {
    font-size: 13px;
    color: #888;
}

/* --- 蓝色小标签 (Daily Life) --- */
/* 这里建议在属性编辑器里把 label_5 和 label_9 的 objectName 统一成 tagLabel */
QLabel#label_5, QLabel#label_9 {
    color: #4a90e2;
    background-color: #eef5ff;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: bold;
}

QFrame#test_card {

    background-color: white;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    padding: 10px;
}

QFrame#test_card:hover {

    border: 1px solid #3b82f6;
    background-color: #f9fafb;
}

QPushButton#Recite_button {
    qproperty-icon: url(resources/icons/book-alt.png);
    qproperty-iconSize: 20px 20px;
}

QPushButton#Favourite_button {
    qproperty-icon: url(resources/icons/headphones.png);
    qproperty-iconSize: 20px 20px;
}

QPushButton#Profile_button {
    qproperty-icon: url(resources/icons/user-speaking.png);
    qproperty-iconSize: 20px 20px;
}

QPushButton#Discussion_button {
    qproperty-icon: url(resources/icons/bank.png);
    qproperty-iconSize: 20px 20px;
}

QPushButton#Exit_button{
	qproperty-icon:url(resources/icons/exit.png);
	qproperty-iconSize:20px 20px;
}
</string>
