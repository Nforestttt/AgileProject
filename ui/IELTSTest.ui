  <property name="styleSheet">
   <string notr="true">QWidget#Form {
    background-color: #f6f7fb;
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 14px;
}


/* =========================
   Header Bar
========================= */

QWidget#Header_bar {
    background-color: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 10px;
}

QLabel#Test_title {
    font-size: 20px;
    font-weight: 700;
    color: #111827;
}

QLabel#Timer_label {
    font-size: 18px;
    font-weight: 600;
    color: #ef4444;
	qproperty-icon: url(resources/icons/alarm-clock.png);
	qproperty-iconsize:24px 24px;
}


/* =========================
   Audio Player
========================= */

QWidget#Audio_player {
    background-color: white;
    border-bottom: 1px solid #e5e7eb;
    padding: 8px;
}

/* 播放按钮 */

QPushButton#pushButton {
    background-color: #2563eb;
    color: white;
    border-radius: 6px;
    padding: 6px 14px;
    font-size: 14px;
    font-weight: bold;
}

QPushButton#pushButton:hover {
    background-color: #1d4ed8;
}

QPushButton#pushButton:pressed {
    background-color: #1e40af;
}


/* =========================
   Slider
========================= */

QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #2563eb;
    border: none;
    width: 14px;
    height: 14px;
    margin: -4px 0;
    border-radius: 7px;
}

QSlider::handle:horizontal:hover {
    background: #1d4ed8;
}


/* =========================
   主内容区域
========================= */

QWidget#main_content {
    background: transparent;
}


/* =========================
   ScrollArea
========================= */

QScrollArea {
    border: none;
}

#scrollAreaWidgetContents {
    background: white;
    border-radius: 8px;
    padding: 20px;
}

/* 左侧题目区域 */
QScrollArea#scrollArea {
    background: transparent;
}


/* =========================
   右侧答题区域
========================= */

QScrollArea#scrollArea_2 {
    background: transparent;
}

#scrollAreaWidgetContents_2 {
    background: white;
    border-radius: 10px;
    padding: 15px;
    border: 1px solid #e5e7eb;
}


/* =========================
   题号
========================= */

QLabel#label_2,
QLabel#label_3,
QLabel#label_4,
QLabel#label_5,
QLabel#label_6,
QLabel#label_7,
QLabel#label_8,
QLabel#label_9,
QLabel#label_10,
QLabel#label_11 {

    font-weight: 600;
    color: #374151;
}


/* =========================
   输入框
========================= */

QLineEdit {

    border: 1px solid #d1d5db;
    border-radius: 6px;
    padding: 6px 8px;
    background: white;
}

QLineEdit:hover {
    border: 1px solid #9ca3af;
}

QLineEdit:focus {
    border: 1px solid #2563eb;
    background: #f9fbff;
}


/* =========================
   Navigation bar
========================= */

QWidget#Navigation_bar {

    background-color: white;
    border-top: 1px solid #e5e7eb;
    padding: 10px;
}


/* Exit 按钮 */

QPushButton#Exit_button {

    background-color: #e5e7eb;
    border-radius: 6px;
    padding: 8px 16px;
}

QPushButton#Exit_button:hover {

    background-color: #d1d5db;
}


/* Submit 按钮 */

QPushButton#pushButton_3 {

    background-color: #10b981;
    color: white;
    border-radius: 6px;
    padding: 8px 20px;
    font-weight: 600;
}

QPushButton#pushButton_3:hover {

    background-color: #059669;
}


/* =========================
   ScrollBar
========================= */

QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 6px;
}

QScrollBar::handle:vertical {
    background: #d1d5db;
    border-radius: 3px;
}

QScrollBar::handle:vertical:hover {
    background: #9ca3af;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QLabel#Score_label{

    font-size:18px;
    font-weight:700;
    color:#2563eb;

}</string>
