  <property name="styleSheet">
   <string notr="true">/* ================= Reply Card ================= */

QWidget#Form {

    background-color: white;

    border-radius: 12px;
    border: 1px solid #f0f0f0;

    padding: 10px;
}


/* hover 效果 */

QWidget#Form:hover {

    background-color: #fff7f9;
    border: 1px solid #ff8fa3;
}


/* ================= 用户名 ================= */

QWidget#Form QLabel#name {

    font-size: 13px;
    font-weight: 600;
    color: #333333;
}


/* hover 用户名变粉 */

QWidget#Form:hover QLabel#name {
    color: #ff6b81;
}


/* ================= 时间 ================= */

QWidget#Form QLabel#time {

    font-size: 11px;
    color: #999999;
}


/* ================= 回复内容 ================= */

QWidget#Form QLabel#label_content {

    font-size: 14px;
    color: #444444;
    padding-top: 4px;
    padding-bottom: 4px;
}


/* ================= 点赞 ================= */

QWidget#Form QLabel#like {

    font-size: 12px;
    color: #ff6b81;
}


/* ================= Like 按钮 ================= */

QWidget#Form QPushButton {

    border: none;
    background: transparent;

    font-size: 12px;
    color: #999999;
}


/* hover 点赞按钮 */

QWidget#Form QPushButton:hover {

    color: #ff6b81;
}


/* ================= 子组件透明 ================= */

QWidget#Form * {

    background: transparent;
}</string>
