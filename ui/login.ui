  <property name="styleSheet">
   <string notr="true">QWidget {
    font-family: &quot;Segoe UI&quot;,&quot;Microsoft YaHei&quot;;
    font-size: 14px;
    color: #333333;
}


/* ============================= */
/* 背景图片 */
/* ============================= */

QWidget#Form {
    border-image: url(resources/images/login-picture3.jpg) 0 0 0 0 stretch stretch;
}


/* ============================= */
/* 中间半透明卡片 */
/* ============================= */

QFrame#frame {
    background-color: rgba(255,255,255,180);
    border-radius: 15px;
}


/* ============================= */
/* 让布局容器透明 */
/* ============================= */

QWidget#verticalLayoutWidget {
    background: transparent;
}


/* ============================= */
/* LOGO标题 */
/* ============================= */

QLabel#label,
QLabel#label_4 {
    font-size: 28px;
    font-weight: bold;
    color: #4A90E2;
    background: transparent;
}


/* ============================= */
/* 表单标签 */
/* ============================= */

QLabel#label_2,
QLabel#label_3 {
    font-size: 15px;
    color: #555555;
    background: transparent;
}


/* ============================= */
/* 输入框 */
/* ============================= */

QLineEdit {

    background-color: white;

    border: 1px solid #dcdcdc;

    border-radius: 8px;

    padding: 6px 10px;

    min-height: 32px;
}


/* 输入框获得焦点 */

QLineEdit:focus {

    border: 2px solid #4A90E2;

}


/* ============================= */
/* Login 按钮 */
/* ============================= */

QPushButton#pushButton {

    background-color: #4A90E2;

    color: white;

    border-radius: 8px;

    font-size: 15px;

    font-weight: bold;

    min-height: 36px;
}


/* Hover */

QPushButton#pushButton:hover {

    background-color: #357ABD;

}


/* 点击 */

QPushButton#pushButton:pressed {

    background-color: #2c5fa3;

}


/* ============================= */
/* Register 按钮 */
/* ============================= */

QPushButton#pushButton_2 {

    background: transparent;

    color: #4A90E2;

    border: none;
}


/* hover */

QPushButton#pushButton_2:hover {

    text-decoration: underline;

}


/* ============================= */
/* Forgot password */
/* ============================= */

QPushButton#pushButton_3 {

    background: transparent;

    color: #999999;

    border: none;

}


/* hover */

QPushButton#pushButton_3:hover {

    color: #4A90E2;

}</string>
